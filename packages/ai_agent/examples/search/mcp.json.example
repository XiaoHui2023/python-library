{
  "mcpServers": {
    "cursor_cli": {
      "command": "<absolute-path-to-uv>",
      "args": [
        "run",
        "--project",
        "<absolute-path-to-tools/cursor_cli>",
        "python",
        "-m",
        "mcp_tool_cursor_cli"
      ],
      "cwd": "<absolute-path-to-tools/cursor_cli>",
      "env": {
        "UV_PROJECT_ENVIRONMENT": "<absolute-path-to-uv-environments/mcp-tool-cursor-cli>",
        "PYTHONUNBUFFERED": "1",
        "CURSOR_AGENT_TIMEOUT": "120",
        "CURSOR_AGENT_DEFAULT_MODE": "agent",
        "CURSOR_AGENT_DEFAULT_SANDBOX": "disabled",
        "CURSOR_AGENT_DEFAULT_MODEL": "composer-2.5-fast",
        "CURSOR_API_KEY": "<your-cursor-api-key>"
      }
    }
  }
}

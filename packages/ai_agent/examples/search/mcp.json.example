{
  "mcpServers": {
    "current_time": {
      "command": "uvx",
      "args": [
        "--from",
        "<absolute-path-to-tools/current_time>",
        "mcp-tool-current-time"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "cursor_cli": {
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        "<absolute-path-to-tools/cursor_cli>",
        "mcp-tool-cursor-cli"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "CURSOR_API_KEY": "<your-cursor-api-key>",
        "CURSOR_AGENT_TIMEOUT": "600",
        "CURSOR_AGENT_DEFAULT_MODE": "agent",
        "CURSOR_AGENT_DEFAULT_SANDBOX": "disabled",
        "CURSOR_AGENT_DEFAULT_MODEL": "composer-2.5-fast",
        "CURSOR_CLI_DEBUG_LOG": "<optional-absolute-path-to-scratch/cursor_cli.mcp.stderr.log>"
      }
    }
  }
}

LLM_API_KEY=

LLM_BASE_URL=https://api.openai.com/v1

LLM_MODEL=gpt-4o-mini

LLM_THINKING_ENABLED=true



# MCP：复制 mcp.json.example → mcp.json（gitignore），填写 uv 与 tools/cursor_cli 绝对路径。
# cursor_cli 的 CURSOR_* 写在 mcp.json 各 server 的 env；示例 .env 仅 LLM_*，不注入 MCP 子进程。
# 本地开发用 uv run + cwd + UV_PROJECT_ENVIRONMENT 直接跑 cursor_cli 源码（与 tools/cursor_cli/mcp.json 一致）。
# 验收：examples/search/run_demo.bat 或包根 run.bat examples/search


{
  "mcpServers": {
    "cursor_cli": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/XiaoHui2023/tools.git#subdirectory=cursor_cli",
        "mcp-tool-cursor-cli"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "CURSOR_API_KEY": "<your-cursor-api-key>",
        "CURSOR_AGENT_TIMEOUT": "600",
        "CURSOR_AGENT_DEFAULT_MODE": "agent",
        "CURSOR_AGENT_DEFAULT_SANDBOX": "disabled",
        "CURSOR_AGENT_DEFAULT_MODEL": "composer-2.5-fast"
      }
    }
  }
}
